{
  "expo": {
    "name": "V-Prep",
    "slug": "vprep",
    "scheme": [
      "vprep",
      "com.vprep.app"
    ],
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F2"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vprep.app"
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#60164B"
      },
      "package": "com.vprep.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.USE_EXACT_ALARM"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Allow V-Prep to access your microphone to record interview answers."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow V-Prep to access your photos to upload your handwritten coding solutions.",
          "cameraPermission": "Allow V-Prep to use your camera to capture handwritten coding solutions for OCR scoring."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#60164B",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "V-Prep"
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "c685ee8c-cb64-425a-bc94-f026fa70af9d"
      }
    }
  }
}
