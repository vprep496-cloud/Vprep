# V-Prep Mobile Environment
# Copy to `.env` for local Expo development.

EXPO_PUBLIC_API_URL=http://192.168.1.5:8000
EXPO_PUBLIC_ADMIN_URL=http://192.168.1.5:3000

# Expo Go Google OAuth proxy. Keep this value the same on every laptop.
# Add this exact URI to Google Cloud Console -> VPREP Web -> Authorized redirect URIs.
EXPO_PUBLIC_EXPO_OWNER=vprep
EXPO_PUBLIC_EXPO_SLUG=vprep
EXPO_PUBLIC_EXPO_AUTH_PROXY_REDIRECT_URI=https://auth.expo.io/@vprep/vprep

# Google OAuth client IDs.
# Use Android/iOS OAuth client IDs for EAS development and production builds.
# Use the Web OAuth client ID for Expo Go and web builds.
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=873343811059-sonmgd9h0qojmg2mnpdlccqo9pp8ork5.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=873343811059-17utdkhs1fu1a7tgrtr848ng843ld29l.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=873343811059-9boh5f1ao9d0bcbns1n9fq659jfms926.apps.googleusercontent.com

# Firebase web/mobile client config.
EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSyA1fXArD3DQt_pDggAlyp9KYx4nlf1nf_g
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=vprep-d4246.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=vprep-d4246
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=vprep-d4246.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=873343811059
EXPO_PUBLIC_FIREBASE_APP_ID=1:873343811059:web:1ab3a863271b66cd03a686
