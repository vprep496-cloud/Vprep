# V-Prep Backend Environment
# Copy to `.env` for local development. Never commit real secrets.

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=vprep

# Firebase Admin SDK
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# App security
SECRET_KEY=replace-with-a-long-random-secret

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:8082,http://localhost:19000,http://localhost:19006,exp://localhost:8081,exp://localhost:8082

# Local AI provider
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_REQUEST_TIMEOUT_SECONDS=120
OLLAMA_HEALTH_TIMEOUT_SECONDS=5

# Generation behavior. Scoring stays low-temperature for consistency; admin
# question/plan generation uses AI_CREATIVE_TEMPERATURE.
AI_TEMPERATURE=0.2
AI_CREATIVE_TEMPERATURE=0.7
AI_TOP_P=0.95
AI_MAX_OUTPUT_TOKENS=8192
