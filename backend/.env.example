# V-Prep Backend Environment
# Copy to `.env` for local development. Never commit real secrets.

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=vprep

# Firebase Admin SDK
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# App security
SECRET_KEY=replace-with-a-long-random-secret

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:8082,http://localhost:19000,http://localhost:19006,exp://localhost:8081,exp://localhost:8082

# AI provider
AI_PROVIDER=gemini

# Gemini API key. Prefer GEMINI_API_KEY. GOOGLE_API_KEY is supported as a fallback.
GEMINI_API_KEY=replace-with-your-google-ai-studio-key
GOOGLE_API_KEY=

# Gemini model routing. Scoring uses a stable multimodal model with structured
# output support; health checks use the lower-latency lite model.
GEMINI_TEXT_MODEL=gemini-3.5-flash
GEMINI_JSON_MODEL=gemini-3.5-flash
GEMINI_SCORING_MODEL=gemini-3.5-flash
GEMINI_MULTIMODAL_MODEL=gemini-3.5-flash
GEMINI_HEALTH_MODEL=gemini-3.1-flash-lite

# Generation behavior. Scoring stays low-temperature for consistency; admin
# question/plan generation uses AI_CREATIVE_TEMPERATURE.
AI_TEMPERATURE=0.2
AI_CREATIVE_TEMPERATURE=0.7
AI_TOP_P=0.95
AI_MAX_OUTPUT_TOKENS=8192
